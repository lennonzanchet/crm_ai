# Copie este arquivo para .env antes de usar Prisma ou a API:
# cp .env.example .env

# URL de conexão usada pelo Prisma (Etapa 4)
DATABASE_URL="postgresql://crm:crm@localhost:5433/crm?schema=public"

# Credenciais do container (espelham docker-compose.yml)
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=crm
